# platform_api үшін мысал. Нақты мәнді .env ішіне көшіріп толтырыңыз (репоға .env коммит етпеңіз).
# Толығырақ: репо түбіндегі .env.example

# --- Міндетті (JWT) ---
# RAQAT_JWT_SECRET=кемінде_32_таңба...

# --- 1) Google id_token тексеру (Gmail / Google кіру) ---
# Google Cloud Console → OAuth 2.0 Client IDs (Web, iOS, Android) — client id-лерді үтірмен:
# RAQAT_GOOGLE_OAUTH_AUDIENCE=xxxxx.apps.googleusercontent.com,yyyyy.apps.googleusercontent.com

# --- Sign in with Apple (native iOS; әдетте bundle id) ---
# RAQAT_APPLE_OAUTH_AUDIENCE=kz.raqat.app

# --- Телефон OTP (HMAC; бос болса ұзын RAQAT_JWT_SECRET қолданылады, кемінде 16 таңба) ---
# RAQAT_OTP_HMAC_SECRET=...

# --- Телефон + SMS: бір режим таңдаңыз ---
#
# Өндіріс (нақты SMS): Twilio үш мәнін толтырыңыз. RAQAT_PHONE_OTP_DEV қоспаңыз.
# https://console.twilio.com/ — Account SID, Auth Token, жіберуші нөмір (сатып алынған немесе trial).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
#
# Даму (SMS жоқ): тек төмендегіні қосыңыз — API /auth/phone/start жауабында dev_otp келеді.
# RAQAT_PHONE_OTP_DEV=1
#
# Екеуі де жоқ болса: POST /api/v1/auth/phone/start → 503 (SMS_NOT_CONFIGURED).

# Қосымша үлгі: infra/docker/platform-api.env.example
