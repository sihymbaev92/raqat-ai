

# Optional: in-memory state TTL (seconds) and AI rate limit
# USER_STATE_TTL_SECONDS=21600
# USER_LANG_TTL_SECONDS=2592000
# TASBIH_TTL_SECONDS=259200
# STATE_MAX_ENTRIES=100000
# AI_RATE_LIMIT_SECONDS=8
# AI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.5-flash-lite

# Құран транскрипциясы: default | pedagogical (1-сүре эталоны + қалғанына тыныс жақындату)
# QURAN_TRANSLIT_STYLE=pedagogical

# Telegram AI күту (сек) және platform_api httpx оқу (сек; бот күтуінен сәл кіші болуы керек)
# RAQAT_BOT_AI_WAIT_TOTAL=68
# RAQAT_PLATFORM_AI_HTTP_TIMEOUT=52
#
# Орталық AI (бот → platform_api → Gemini). Екеуі де толтырылса, бот тікелей Gemini орнына API шақырады.
# RAQAT_PLATFORM_API_BASE=http://127.0.0.1:8787
# RAQAT_AI_PROXY_SECRET=ұзын_құпия_жол_бірдей_API_және_ботта
#
# /start кезінде JWT + identity: төмендегі RAQAT_BOT_LINK_SECRET пен RAQAT_PLATFORM_API_BASE бірге (API серверімен бірдей құпия)
# Bot API-only (контент fallback өшіруді кезеңдеп енгізу)
# RAQAT_BOT_API_ONLY=1
# Толық бір орталық режим: AI де тек platform_api арқылы (тікелей Gemini fallback жоқ)
# RAQAT_SINGLE_SOURCE_MODE=1

# API серверінде (.env немесе systemd): GEMINI_API_KEY=... және сол RAQAT_AI_PROXY_SECRET
#
# Redis (distributed AI rate limit + cache + Celery broker; infra/docker/docker-compose.yml)
# Мысал: redis://localhost:6379 — жолақсыз порттан кейін /0 автоматты қосылады
# RAQAT_REDIS_URL=redis://localhost:6379
# Өндірісте Redis жоқ болса API іске қосылмайды. Тек pytest: RAQAT_REDIS_REQUIRED=0
# RAQAT_REDIS_REQUIRED=1
# AI rate limit: Redis ZSET (multi-worker). 0=тек in-memory fallback
# RAQAT_AI_RL_USE_REDIS=1
# Readiness: Redis күйі /ready ішінде
# RAQAT_READINESS_REQUIRE_REDIS=0
#
# AI exact cache (Redis, L1): бірдей prompt → жауап TTL ішінде
# RAQAT_AI_EXACT_CACHE=1
# RAQAT_AI_CACHE_TTL_SECONDS=1800
# RAQAT_AI_CACHE_MAX_CHARS=12000
#
# AI semantic cache (L2, embedding + cosine; GEMINI_API_KEY қажет)
# RAQAT_AI_SEMANTIC_CACHE=0
# RAQAT_AI_SEM_CACHE_MIN_SIM=0.88
# RAQAT_AI_SEM_CACHE_MAX_ENTRIES=200
# RAQAT_AI_EMBED_MODEL=text-embedding-004
#
# Celery (AI/TTS/сурет async_mode; docker compose --profile workers)
# RAQAT_QUEUE_BACKEND=celery
# RAQAT_CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# RAQAT_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# RAQAT_CELERY_RESULT_EXPIRES_SEC=3600
# RAQAT_CELERY_VISIBILITY_TIMEOUT_SEC=7200
# RAQAT_CELERY_TASK_TIME_LIMIT_SEC=600
# RAQAT_CELERY_TASK_SOFT_TIME_LIMIT_SEC=540
# RAQAT_CELERY_DEFAULT_RETRY_DELAY_SEC=30
# RAQAT_CELERY_TASK_MAX_RETRIES=5

# AI: Google Search=1 болса ~40/40/20; =0 немесе SDK қолдамаса жауап тек ішкі DB үзінділеріне сүйенеді (интернет жоқ)
# RAQAT_AI_ENABLE_GOOGLE_SEARCH=1
# RAQAT_AI_QURAN_CONTEXT_CHARS=4200
# RAQAT_AI_HADITH_CONTEXT_CHARS=4200
# RAQAT_AI_LANG=kk

# Оқу-only /quran|/hadith|/metadata — толтырылса клиент header жіберуі керек: X-Raqat-Content-Secret
# RAQAT_CONTENT_READ_SECRET=...
# Expo: EXPO_PUBLIC_RAQAT_CONTENT_SECRET=... (fetchMetadataChanges / fetchQuranSurahs)
# Expo: EXPO_PUBLIC_RAQAT_API_ONLY=1  # prod-та fallback-тарды өшіру (API-only экожүйе)

# Келешек PostgreSQL DSN (қазір бос қалдыруға болады; толығырақ docs/MIGRATION_SQLITE_TO_POSTGRES.md)
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/raqat

# platform_api JWT (минимум 32 таңба) + bootstrap логин
# RAQAT_JWT_SECRET=...
# RAQAT_AUTH_USERNAME=admin
# Өндірісте: bcrypt hash (passlib)
# RAQAT_AUTH_PASSWORD_BCRYPT=$2b$12$...
# Тек dev: RAQAT_AUTH_PASSWORD=...
# RAQAT_JWT_EXPIRE_MINUTES=1440  # legacy; жаңа: RAQAT_JWT_ACCESS_EXPIRE_MINUTES
# RAQAT_JWT_ACCESS_EXPIRE_MINUTES=30
# RAQAT_JWT_REFRESH_EXPIRE_DAYS=30
# RAQAT_JWT_REFRESH_SECRET=...  # бос болса RAQAT_JWT_SECRET қолданылады

# Telegram ↔ platform_user_id JWT шығару (POST /api/v1/auth/link/telegram, X-Raqat-Bot-Link-Secret)
# RAQAT_BOT_LINK_SECRET=ұзын_құпия_тек_серверде

# Қолданба кіруі: Google / Apple / телефон OTP (platform_api: /api/v1/auth/oauth/*, /api/v1/auth/phone/*)
# Google id_token тексеру: OAuth client id(лер) — үтірмен (iOS, Android, Web client)
# RAQAT_GOOGLE_OAUTH_AUDIENCE=123456789-xxx.apps.googleusercontent.com,123456789-yyy.apps.googleusercontent.com
# Sign in with Apple (native): әдетте iOS bundle id
# RAQAT_APPLE_OAUTH_AUDIENCE=kz.raqat.app
# OTP кодының HMAC (бос болса ұзын RAQAT_JWT_SECRET қолданылады, кемінде 16 таңба)
# RAQAT_OTP_HMAC_SECRET=...
# SMS (Twilio): толтырылмаса телефон кіруі 503 қайтарады; дамуда RAQAT_PHONE_OTP_DEV=1
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# RAQAT_PHONE_OTP_DEV=1

# Өндіріс AI rate limit (RAQAT_ENV=production болмаса әдепкі жоғары лимит)
# RAQAT_ENV=production
# RAQAT_AI_RL_WINDOW_SECONDS=60
# RAQAT_AI_RL_MAX_PER_WINDOW=30
# RAQAT_AI_RL_DISABLED=0
