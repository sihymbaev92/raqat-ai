# Production APK / AAB жинау алдында көшіріп атауыңыз: .env.production (gitке кірмейді).
# Gradle: npm run build:apk / npm run build:aab — load-raqat-expo-env.sh осы файлды соңғы болып жүктейді.
# EAS: eas secret:create — EXPO_PUBLIC_RAQAT_API_BASE

# API: нақты HTTPS доменіңіз (nginx/TLS соңы). YOUR_API_DOMAIN → өз доменіңіз.
# EXPO_PUBLIC_RAQAT_API_BASE=https://YOUR_API_DOMAIN
# EXPO_PUBLIC_RAQAT_API_BASE=https://api.example.com
# EXPO_PUBLIC_RAQAT_API_BASE=http://1.2.3.4:8787

# Қауіпсіздік: AI/content secret клиентке берілмейді.
# Толық AI үшін қолданбада кіру (JWT) керек.
