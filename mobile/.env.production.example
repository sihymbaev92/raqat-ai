# Production APK / AAB жинау алдында көшіріп атауыңыз: .env.production (gitке кірмейді).
# Gradle: npm run build:apk — load-raqat-expo-env.sh осы файлды соңғы болып жүктейді.
# EAS: eas secret:create — EXPO_PUBLIC_RAQAT_API_BASE (және қажет болса AI кілті).

# Нақты сервер (HTTP немесе HTTPS; телефон желісінен қолжетімді болуы керек)
EXPO_PUBLIC_RAQAT_API_BASE=https://api.example.com

# Халал AI / Raqat AI — сервердегі RAQAT_AI_PROXY_SECRET-пен бірдей (қосымша)
# EXPO_PUBLIC_RAQAT_AI_SECRET=

# Құран/метадата контент қорғауы — RAQAT_CONTENT_READ_SECRET (опция)
# EXPO_PUBLIC_RAQAT_CONTENT_SECRET=
