{
  "name": "raqat-mobile",
  "version": "1.0.4",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:lan": "EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0 expo start --lan",
    "start:vps": "bash scripts/expo-vps.sh",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:full": "npm run lint && jest --ci",
    "prebuild": "expo prebuild",
    "build:apk": "node scripts/build-apk-node.cjs release",
    "build:aab": "node scripts/build-apk-node.cjs aab",
    "build:apk:debug": "node scripts/build-apk-node.cjs debug",
    "eas:apk": "eas build --platform android --profile preview --non-interactive",
    "bundle:quran-data": "bash scripts/fetch-bundled-quran.sh",
    "export:quran-kk-bundle": "cd .. && .venv/bin/python scripts/export_quran_kk_bundled_json.py --db global_clean.db --out mobile/assets/bundled/quran-kk-from-db.json",
    "import:quran-erlan": "cd .. && bash scripts/run_erlan_quran_import.sh",
    "export:hadith-json": "cd .. && .venv/bin/python scripts/hadith_corpus_sync.py export --db global_clean.db --out mobile/assets/bundled/hadith-from-db.json",
    "export:hadith-json:kk-only": "cd .. && .venv/bin/python scripts/hadith_corpus_sync.py export --db global_clean.db --out mobile/assets/bundled/hadith-from-db.json --only-with-kk",
    "fill:hadith-en-ru": "cd .. && bash scripts/run_hadith_fawaz_en_ru.sh",
    "hadith:quality": "cd .. && .\\.venv\\Scripts\\python.exe scripts\\hadith_quality_gate.py",
    "hadith:normalize": "cd .. && .\\.venv\\Scripts\\python.exe scripts\\normalize_hadith_kk_terms.py",
    "e2e:build:emu": "detox build -c android.emu.debug",
    "e2e:test:emu": "detox test -c android.emu.debug",
    "e2e:build:ci": "detox build -c android.att.ci",
    "e2e:test:ci": "detox test -c android.att.ci --loglevel verbose"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sensors": "~15.0.8",
    "expo-speech": "14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "hijri-converter": "^1.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~54.0.10",
    "detox": "^20.51.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.12",
    "typescript": "~5.9.2"
  }
}
