      "phaseRule": null
    },
    {
      "id": 92,
      "slug": "sallallahu_alayhi_wa_sallam_short",
      "textAr": "صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ",
      "textKk": "Саллаллаһу 'аләйһи уа саллам",
      "translitKk": "Саллаллаһу 'аләйһи уа саллам",
