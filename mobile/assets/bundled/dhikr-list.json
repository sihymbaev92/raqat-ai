      "phaseRule": null
    },
    {
      "id": 94,
      "slug": "allahumma_ghfir_muslimin",
      "textAr": "اللَّهُمَّ اغْفِرْ لِلْمُسْلِمِينَ وَالْمُسْلِمَاتِ",
      "textKk": "Аллаһуммағфир лил-муслимин",
