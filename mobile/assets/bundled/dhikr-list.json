      "textAr": "اللَّهُمَّ أَنْتَ السَّلَامُ وَمِنْكَ السَّلَامُ",
      "textKk": "Аллаһумма антас-Салам",
      "translitKk": "Аллаһумма антас-саламу уа минкас-салам",
      "meaningKk": "Сен Саламсың, салаамат Сенен — намаз сәлемінен кейінгі сүннет зікір.",
      "defaultTarget": 30,
      "phaseRule": null
    },
    {
      "id": 79,
      "slug": "allahumma_ftah_li",
      "textAr": "اللَّهُمَّ افْتَحْ لِي أَبْوَابَ رَحْمَتِكَ",
      "textKk": "Аллаһуммафтaҳ ли абwаба рахматик",
      "translitKk": "Аллаһумма фтаҳ ли абwаба рахматик",
      "meaningKk": "Мейірім есіктерін аш (намаз сәлемінен кейін жиі).",
      "defaultTarget": 20,
      "phaseRule": null
    },
    {
      "id": 80,
      "slug": "allahumma_inni_zalamtu",
      "textAr": "اللَّهُمَّ إِنِّي ظَلَمْتُ نَفْسِي ظُلْمًا كَثِيرًا",
      "textKk": "Аллаһумма инни заламту нафси",
      "translitKk": "Аллаһумма инни заламту нафси зulман касиран",
      "meaningKk": "Нәпсіме көп зұлымдық істедім (истигфар басы).",
      "defaultTarget": 10,
      "phaseRule": null
    },
    {
      "id": 81,
      "slug": "la_mani_atayta",
      "textAr": "لَا مَانِعَ لِمَا أَعْطَيْتَ وَلَا مُعْطِيَ لِمَا مَنَعْتَ",
      "textKk": "Ла мани лима а'тайта (толығы)",
      "translitKk": "Ла мани лима а'тайта уа ла му'ти лима мана'та",
      "meaningKk": "Бергеніңді тоқтатпайтын жоқ (қысқа нұсқа).",
      "defaultTarget": 30,
      "phaseRule": null
    },
    {
      "id": 82,
      "slug": "allahumma_rzuqni",
      "textAr": "اللَّهُمَّ ارْزُقْنِي حَلَالًا طَيِّبًا",
      "textKk": "Аллаһумма рзуқни ҳалалән таййибан",
      "translitKk": "Аллаһумма рзуқни ҳалалән таййибан",
      "meaningKk": "Таза халал ризық бер.",
      "defaultTarget": 50,
      "phaseRule": null
    },
    {
      "id": 83,
      "slug": "allahumma_qini_azab",
      "textAr": "اللَّهُمَّ قِنِي عَذَابَكَ يَوْمَ تَبْعَثُ عِبَادَكَ",
      "textKk": "Аллаһумма қини 'азабак",
      "translitKk": "Аллаһумма қини 'азабака йаwма таб'асу 'ибадак",
      "meaningKk": "Қиямет күні азабыңнан сақта (дуа басы).",
      "defaultTarget": 15,
      "phaseRule": null
    },
    {
      "id": 84,
      "slug": "subhan_rabbika_rabbil_izzati",
      "textAr": "سُبْحَانَ رَبِّكَ رَبِّ الْعِزَّةِ عَمَّا يَصِفُونَ",
      "textKk": "Субхана раббика раббил-'иззати",
      "translitKk": "Субхана раббика раббил-'иззати 'амма йасифун",
