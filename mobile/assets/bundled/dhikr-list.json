      "phaseRule": null
    },
    {
      "id": 90,
      "slug": "fa_idha_azamta",
      "textAr": "فَإِذَا عَزَمْتَ فَتَوَكَّلْ عَلَى اللَّهِ",
      "textKk": "Фаиза 'азамта фәтәуаккал 'алаллаһ",
      "translitKk": "Фаиза 'азамта фәтәуаккал 'алаллаһ",
      "meaningKk": "Белгілеп қойсаң, Аллаһқа тәуеккүл ет (3:159).",
