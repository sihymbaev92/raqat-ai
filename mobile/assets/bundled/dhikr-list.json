    {
      "id": 97,
      "slug": "innallaha_yuhibb",
      "textAr": "إِنَّ اللَّهَ يُحِبُّ التَّوَّابِينَ",
      "textKk": "Инналлаһа юһиббут-таwабин",
      "translitKk": "Инналлаһа юһиббут-таwабин",
      "meaningKk": "Расында Аллаһ тәубе еткендерді сүйеді (2:222 үзіндісі).",
