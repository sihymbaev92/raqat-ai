      "phaseRule": null
    },
    {
      "id": 93,
      "slug": "allahumma_salli_muhammadin",
      "textAr": "اللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ",
      "textKk": "Аллаһумма салли 'алә Мухаммад",
