      "phaseRule": null
    },
    {
      "id": 98,
      "slug": "wala_taknatu",
      "textAr": "وَلَا تَيْأَسُوا مِنْ رَوْحِ اللَّهِ",
      "textKk": "Уа ла тай'асу мин рауһиллаһ",
      "translitKk": "Уа ла тай'асу мин рауһиллаһ",
      "meaningKk": "Аллаһтың мейірімінен үміт үзбеңдер (12:87).",
