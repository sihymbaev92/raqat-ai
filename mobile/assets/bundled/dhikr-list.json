      "phaseRule": null
    },
    {
      "id": 96,
      "slug": "allahumma_atina_fidunya",
      "textAr": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً",
      "textKk": "Раббана әтина (екі дүние)",
