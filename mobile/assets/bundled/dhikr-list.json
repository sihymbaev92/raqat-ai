      "phaseRule": null
    },
    {
      "id": 99,
      "slug": "alhamdu_lillahi_hamdan_kathiran",
      "textAr": "الْحَمْدُ لِلَّهِ حَمْدًا كَثِيرًا طَيِّبًا مُبَارَكًا فِيهِ",
      "textKk": "Әлхамдулиллаһи ҳамдан касиран",
      "translitKk": "Әлхамдулиллаһи ҳамдан касиран таййибан мубаракан фиһи",
