      "meaningKk": "Мұсылман ерлер мен әйелдерді кешір.",
      "defaultTarget": 20,
      "phaseRule": null
    },
    {
      "id": 95,
      "slug": "subhanallahi_wa_bihamdihi_adada",
      "textAr": "سُبْحَانَ اللَّهِ عَدَدَ خَلْقِهِ رِضَا نَفْسِهِ",
