<?xml version="1.0" encoding="utf-8"?>
<!--
  Release APK: usesCleartextTraffic=false — HTTP тек төмендегі host-тарға рұқсат.
  Жаңа IP/домен (HTTP): <domain>…</domain> қосып APK қайта жинаңыз.
  Эмулятор → хосттың localhost: http://10.0.2.2:8787 (127.0.0.1 эмуляторда «өзіне» барады).
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">5.75.162.140</domain>
    <domain includeSubdomains="false">10.0.2.2</domain>
    <domain includeSubdomains="false">127.0.0.1</domain>
    <domain includeSubdomains="false">localhost</domain>

    <domain includeSubdomains="false">192.168.0.148</domain>
</domain-config>
</network-security-config>
