# Бұл файлды `keystore.properties` деп көшіріп, мәндерді толтырыңыз (keystore.properties — .gitignore).
# JKS жасау (JDK keytool):
#   keytool -genkeypair -v -keystore keystore/raqat-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias raqatrelease
#
# storeFile жолы android/ қалтасына қатысты (мысалы keystore/raqat-release.jks).
storeFile=keystore/raqat-release.jks
keyAlias=raqatrelease
storePassword=өз_құпия_сөзі
keyPassword=өз_құпия_сөзі
